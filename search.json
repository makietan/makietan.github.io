---
---
[
  {% for page in site.pages %}
  {% if page.url contains '.html' %}
  {% unless page.url contains '/blog/' %}
  {% unless page.url == '/search.html' %}
  {% unless page.url == '/search_en.html' %}
  {% unless page.url == '/404.html' %}
  {% unless page.url contains '/page/' and page.url contains '/index.html' %}
  {% capture page_title %}{{ page.title | replace: '\\', ' ' | replace: '\t', ' ' }}{% if page.subtitle %} — {{ page.subtitle | remove: '\\' }}{% endif %}{% endcapture %}
  {
    "title": {{ page_title | jsonify }},
    "url": {{ page.url | jsonify }},
    "content": {{ page.content | strip_html | strip_newlines | replace: '\\', ' ' | replace: '\\', ' ' | replace: '\r', ' ' | replace: '\n', ' ' | replace: '\t', ' ' | replace: '"', ' ' | jsonify }}
  },
  {% endunless %}
  {% endunless %}
  {% endunless %}
  {% endunless %}
  {% endunless %}
  {% endif %}
  {% endfor %}

  {% for post in site.posts %}
  {
    "title": {{ post.title | replace: '\\', ' ' | replace: '\t', ' ' | jsonify }},
    {% assign sortedTagNames = post.tags | sort %}
    "tags": [{% for tagName in sortedTagNames %}{"tagName" : {{ tagName | jsonify }}, "count": {{ site.tags[tagName].size}}}{% unless forloop.last %}, {% endunless %}{% endfor %}],
    "url": {{ post.url | jsonify }},
    "date": {"year": {{ post.date | date: "%Y" | jsonify }}, "month": {{ post.date | date: "%m" | jsonify }}, "day": {{ post.date | date: "%d" | jsonify }}},
    "content": {{ post.content | strip_html | strip_newlines | replace: '\\', ' ' | replace: '\\', ' ' | replace: '\r', ' ' | replace: '\n', ' ' | replace: '\t', ' ' | replace: '"', ' ' | jsonify }}
  }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]